<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- Payment payment = new Payment(); -->
	<bean id="payment" class="com.rays.ioc.Payment">
		<property name="balance" value="100"></property>
	</bean>

	<!-- Inventry inventry = new Inventry(); -->
	<bean id="inventry" class="com.rays.ioc.Inventry">
		<property name="stock" value="10"></property>
	</bean>


	<bean id="order" class="com.rays.ioc.Order">
		<property name="inventry" ref="inventry"></property>
		<property name="payment" ref="payment"></property>
	</bean>

</beans>